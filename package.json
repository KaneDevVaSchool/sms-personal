{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "dev:stack": "node ./node_modules/concurrently/dist/bin/concurrently.js \"php artisan serve\" \"php artisan queue:listen --tries=1 --timeout=0\" \"npm run dev\" --names server,queue,vite --kill-others-on-fail",
        "dev:logs": "php artisan pail --timeout=0"
    },
    "devDependencies": {
        "@inertiajs/vue3": "^2.0.0",
        "@tailwindcss/forms": "^0.5.3",
        "@tailwindcss/vite": "^4.0.0",
        "@types/node": "^25.9.1",
        "@vitejs/plugin-vue": "^6.0.0",
        "autoprefixer": "^10.4.12",
        "concurrently": "^9.0.1",
        "laravel-vite-plugin": "^3.1",
        "postcss": "^8.4.31",
        "tailwindcss": "^3.2.1",
        "typescript": "^6.0.3",
        "vite": "^8.0.0",
        "vue": "^3.4.0",
        "vue-tsc": "^3.3.1"
    },
    "dependencies": {
        "@tiptap/pm": "^3.23.6",
        "@tiptap/starter-kit": "^3.23.6",
        "@tiptap/vue-3": "^3.23.6",
        "axios": "^1.16.1",
        "pinia": "^3.0.4",
        "sortablejs": "^1.15.7",
        "vue-router": "^5.0.7",
        "vuedraggable": "^4.1.0"
    }
